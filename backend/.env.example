# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:2717/wellmeds

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_32_character_long_production_secret_key_here
JWT_EXPIRES_IN=7d
COOKIE_SECRET=cookiesecretkey12345!@#

# ─── Razorpay Payment Gateway ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecret
RAZORPAY_WEBHOOK_SECRET=yourwebhooksecret

# ─── Cloudinary Media Storage ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=yourcloudinarycloudname
CLOUDINARY_API_KEY=yourcloudinaryapikey
CLOUDINARY_API_SECRET=yourcloudinaryapisecret

# ─── SMTP Email Configuration ──────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=yoursmtpuser
SMTP_PASS=yoursmtppass
SMTP_FROM=noreply@wellmeds.com

# ─── Google OAuth Credentials ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=yourgoogleclientid.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=yourgoogleclientsecret
