{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/sitemap-:slug*.xml",
      "destination": "/api/sitemap-:slug*.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots.txt"
    },
    {
      "source": "/((?!api|uploads|sitemap|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
